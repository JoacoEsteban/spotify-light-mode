{
  "name": "spotify-light-mode",
  "version": "0.1.2",
  "description": "Bring light mode to Spotify's web player — always on, or only when your OS is in light mode.",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "screenshot": "bun scripts/screenshot.ts",
    "screenshot:fast": "bun scripts/screenshot.ts --skip-build",
    "screenshot:login": "bun scripts/screenshot.ts --login"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "puppeteer-core": "^24.42.0",
    "typescript": "5.8",
    "wxt": "^0.20.25"
  },
  "dependencies": {
    "@types/chroma-js": "^3.1.2",
    "chroma-js": "^3.2.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  }
}
